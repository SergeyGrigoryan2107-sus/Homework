<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Dota 2 — Арена героев</title>
    <!-- Google Fonts + Font Awesome 6 (free) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #05070a;
            color: #eef2ff;
            line-height: 1.5;
            scroll-behavior: smooth;
        }

        /* Тёмная фоновая атмосфера с текстурой и градиентом */
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('https://cdn.cloudflare.steamstatic.com/apps/dota2/images/dota_react//backgrounds/greyfade.jpg');
            background-size: cover;
            background-position: center;
            opacity: 0.12;
            pointer-events: none;
            z-index: -2;
        }

        body::after {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(30, 20, 35, 0.85), rgba(0, 0, 0, 0.95));
            pointer-events: none;
            z-index: -1;
        }

        /* Основной контейнер */
        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 24px;
        }

        /* Шапка */
        header {
            padding: 24px 0 20px;
            border-bottom: 1px solid rgba(220, 60, 50, 0.35);
            backdrop-filter: blur(2px);
            position: sticky;
            top: 0;
            background: rgba(5, 7, 10, 0.7);
            z-index: 100;
        }

        .header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 1px;
            background: linear-gradient(135deg, #e34d3a, #ffb347);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 0 8px rgba(227, 77, 58, 0.3);
        }

        .logo i {
            font-size: 2rem;
            color: #e34d3a;
            background: none;
            -webkit-background-clip: unset;
            background-clip: unset;
            text-shadow: 0 0 5px #d63d2e;
        }

        .nav-links {
            display: flex;
            gap: 32px;
            font-weight: 500;
        }

        .nav-links a {
            color: #ccddee;
            text-decoration: none;
            transition: 0.2s;
            font-size: 1rem;
        }

        .nav-links a:hover {
            color: #ff6b4a;
            text-shadow: 0 0 4px #ff5e3a;
        }

        /* Hero секция */
        .hero {
            text-align: center;
            padding: 60px 0 50px;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(145deg, #f5a65b, #e63e2c);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 16px;
        }

        .hero p {
            font-size: 1.2rem;
            max-width: 700px;
            margin: 0 auto;
            color: #b9c7d9;
        }


.hero-quote {
            margin-top: 28px;
            font-style: italic;
            font-weight: 400;
            border-left: 3px solid #e34d3a;
            background: rgba(30, 20, 35, 0.5);
            display: inline-block;
            padding: 10px 24px;
            border-radius: 40px;
            backdrop-filter: blur(4px);
        }

        /* Панель поиска и фильтрации */
        .search-panel {
            margin: 40px 0 30px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            background: rgba(15, 20, 28, 0.6);
            backdrop-filter: blur(8px);
            padding: 18px 24px;
            border-radius: 60px;
            border: 1px solid rgba(227, 77, 58, 0.3);
        }

        .search-wrapper {
            flex: 2;
            min-width: 200px;
            display: flex;
            align-items: center;
            background: #10161e;
            border-radius: 48px;
            padding: 0 16px;
            border: 1px solid #2a323d;
            transition: all 0.2s;
        }

        .search-wrapper:focus-within {
            border-color: #e34d3a;
            box-shadow: 0 0 6px rgba(227, 77, 58, 0.4);
        }

        .search-wrapper i {
            color: #8a9bb0;
            font-size: 1.1rem;
        }

        #searchInput {
            background: transparent;
            border: none;
            padding: 14px 12px;
            width: 100%;
            color: #f0f3f8;
            font-size: 1rem;
            outline: none;
            font-weight: 400;
        }

        #searchInput::placeholder {
            color: #6a7c8f;
        }

        .action-buttons {
            display: flex;
            gap: 14px;
        }

        .btn-icon {
            background: #1e2a32;
            border: none;
            color: #eef2ff;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
            font-size: 0.9rem;
        }

        .btn-icon i {
            font-size: 1rem;
        }

        .btn-icon:hover {
            background: #d63d2e;
            color: white;
            transform: scale(0.97);
            box-shadow: 0 4px 12px rgba(214, 61, 46, 0.3);
        }

        .hero-counter {
            background: rgba(0, 0, 0, 0.5);
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.9rem;
            font-weight: 500;
            letter-spacing: 0.3px;
            color: #ffbc7a;
        }

        /* Сетка героев */
        .heroes-section {
            margin: 20px 0 60px;
        }

        .section-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 28px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-left: 5px solid #e34d3a;
            padding-left: 18px;
        }

        .heroes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 28px;
            transition: all 0.2s;
        }

        /* Карточка героя */
        .hero-card {
            background: linear-gradient(145deg, #121a24, #0b1117);
            border-radius: 24px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            cursor: pointer;
            border: 1px solid rgba(227, 77, 58, 0.2);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(2px);
        }

        .hero-card:hover {
            transform: translateY(-8px) scale(1.01);
            border-color: #e34d3a;
            box-shadow: 0 18px 30px -8px rgba(227, 77, 58, 0.3);
        }

        .hero-img {


width: 100%;
            height: 230px;
            object-fit: cover;
            display: block;
            transition: transform 0.4s ease;
            background: #1b232d;
        }

        .hero-card:hover .hero-img {
            transform: scale(1.02);
        }

        .hero-info {
            padding: 20px 18px 22px;
        }

        .hero-name {
            font-size: 1.55rem;
            font-weight: 800;
            margin-bottom: 8px;
            background: linear-gradient(135deg, #ffd89a, #e6825c);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: -0.3px;
        }

        .hero-attr {
            display: inline-block;
            background: rgba(227, 77, 58, 0.2);
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            margin-top: 8px;
            margin-right: 8px;
            color: #ffb77c;
        }

        .hero-difficulty {
            display: inline-block;
            background: rgba(90, 100, 120, 0.35);
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 500;
            color: #cbd5e6;
        }

        .empty-message {
            text-align: center;
            grid-column: 1 / -1;
            padding: 60px 20px;
            background: rgba(0, 0, 0, 0.4);
            border-radius: 40px;
            font-size: 1.2rem;
            color: #b9ad9a;
        }

        /* Футер */
        footer {
            border-top: 1px solid rgba(227, 77, 58, 0.3);
            padding: 32px 0;
            margin-top: 40px;
            text-align: center;
            color: #8f9bb3;
            font-size: 0.85rem;
            background: rgba(0, 0, 0, 0.4);
        }

        footer a {
            color: #e68a5e;
            text-decoration: none;
        }

        /* Адаптивность */
        max-width: 780px {
            .container {
                padding: 0 20px;
            }
            .hero h1 {
                font-size: 2.3rem;
            }
            .search-panel {
                flex-direction: column;
                align-items: stretch;
                border-radius: 32px;
                padding: 18px;
            }
            .action-buttons {
                justify-content: flex-start;
            }
            .header-inner {
                flex-direction: column;
                text-align: center;
            }
            .nav-links {
                gap: 24px;
                justify-content: center;
            }
            .heroes-grid {
                gap: 20px;
            }
        }

        max-width: 480px {
            .heroes-grid {
                grid-template-columns: 1fr;
            }
            .btn-icon span {
                display: inline;
            }
        }

        /* Анимация появления карточек */
        .hero-card {
            animation: fadeSlideUp 0.4s ease backwards;
        }

        @keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

<header>
    <div class="container header-inner">
        <div class="logo">
            <i class="fas fa-skull"></i>
            <span>Serwer 2rbina2rista</span>
        </div>
        <div class="nav-links">
            <a href="#">Арена</a>
            <a href="#heroes">Герои</a>
            <a href="#">Сообщество</a>
            <a href="#">Киберспорт</a>
        </div>
    </div>
</header>

<main>
    <div class="container">
        <div class="hero">
            <h1>Битва древних</h1>
            <p>выбери сервер поиграть</p>
            <div class="hero-


quote">
                <i class="fas fa-quote-left" style="margin-right: 8px; color:#e34d3a;"></i> 
                2RBAAINA2RISTA-Франкенштейн
            </div>
        </div>

        <!-- Панель поиска и действий -->
        <div class="search-panel">
            <div class="search-wrapper">
                <i class="fas fa-search"></i>
                <input type="text" id="searchInput" placeholder="Найти песню по назманию... (Pudge, Invoker, Axe...)" autocomplete="off">
            </div>
            <div class="action-buttons">
                <button class="btn-icon" id="clearSearchBtn"><i class="fas fa-times-circle"></i> <span>Сброс</span></button>
                <button class="btn-icon" id="randomHeroBtn"><i class="fas fa-dice-d6"></i> <span>Random hero</span></button>
            </div>
            <div class="hero-counter" id="heroCounter">
                <i class="fas fa-users"></i> <span id="countValue">0</span> героев
            </div>
        </div>

        <!-- Секция героев -->
        <div class="heroes-section" id="heroes">
            <div class="section-title">
                <i class="fas fa-helmet-battle"></i> 
                <span>Воины Древних</span>
            </div>
            <div id="heroesGridContainer" class="heroes-grid">
                <!-- Карточки будут динамически отрисованы через JS -->
                <div class="empty-message">Загрузка героев...</div>
            </div>
        </div>
    </div>
</main>

<footer>
    <div class="container">
        <p>© 2025 Dota 2 Fan Hub. Все материалы принадлежат Valve Corporation. Неофициальный сайт, созданный в честь легендарной игры.</p>
        <p style="margin-top: 10px;"><i class="fab fa-steam"></i> Присоединяйся к битве на <a href="#"> официальном сайте</a></p>
    </div>
</footer>

<script>
    // -------- БАЗА ДАННЫХ ГЕРОЕВ (имя, id для картинки, атрибут, сложность) ----------
    const heroesData = [
        { name: "Pudge", id: "pudge", attribute: "Сила", difficulty: "Средний" },
        { name: "Invoker", id: "invoker", attribute: "Интеллект", difficulty: "Высокий" },
        { name: "Phantom Assassin", id: "phantom_assassin", attribute: "Ловкость", difficulty: "Средний" },
        { name: "Crystal Maiden", id: "crystal_maiden", attribute: "Интеллект", difficulty: "Низкий" },
        { name: "Sniper", id: "sniper", attribute: "Ловкость", difficulty: "Низкий" },
        { name: "Axe", id: "axe", attribute: "Сила", difficulty: "Низкий" },
        { name: "Juggernaut", id: "juggernaut", attribute: "Ловкость", difficulty: "Средний" },
        { name: "Rubick", id: "rubick", attribute: "Интеллект", difficulty: "Высокий" },
        { name: "Earthshaker", id: "earthshaker", attribute: "Сила", difficulty: "Средний" },
        { name: "Storm Spirit", id: "storm_spirit", attribute: "Интеллект", difficulty: "Высокий" },
        { name: "Phantom Lancer", id: "phantom_lancer", attribute: "Ловкость", difficulty: "Средний" },
        { name: "Shadow Fiend", id: "nevermore", attribute: "Ловкость", difficulty: "Средний" }  // nevermore = Shadow Fiend
    ];

    // Корректируем для Shadow Fiend (id: nevermore, но картинка по id nevermore существует)
    // Для удобства подставим правильные имена для картинок (проверено CDN)
    // Заменяем для Shadow Fiend id на 'nevermore' (стандартный образ в API)
    // В heroesData уже "nevermore" - ок.

    // Базовый URL изображений (Steam CDN)
    const IMG_BASE_URL = "https://steamcdn-a.akamaihd.net/apps/dota2/images/heroes/";
    const IMG_SUFFIX = "_full.png";

    // DOM элементы
    const searchInput = document.getElementById('searchInput');
    const clearBtn = document.getElementById('clearSearchBtn');
    const randomBtn = document.getElementById('randomHeroBtn');
    const heroesContainer = document.getElementById('heroesGridContainer');
    const countSpan = document.getElementById('countValue');

    // Текущий фильтр
    let currentFilter = "";

    // Функция рендеринга карточек на основе фи


file.png
PNG · 2 KB
льтра
    function renderHeroes(filterText = "") {
        const lowerFilter = filterText.toLowerCase().trim();
        // Фильтруем массив героев по имени (без учета регистра)
        let filteredHeroes = heroesData.filter(hero => 
            hero.name.toLowerCase().includes(lowerFilter)
        );

        // Обновляем счетчик
        countSpan.textContent = filteredHeroes.length;

        // Если героев нет — показываем сообщение
        if (filteredHeroes.length === 0) {
            heroesContainer.innerHTML = `<div class="empty-message"><i class="fas fa-frown"></i> Героев не найдено... Попробуйте изменить запрос</div>`;
            return;
        }

        // Генерация HTML для карточек
        let cardsHTML = "";
        for (let hero of filteredHeroes) {
            const imageUrl = `${IMG_BASE_URL}${hero.id}${IMG_SUFFIX}`;
            // Запасное изображение на случай ошибки загрузки
            const fallbackImg = "https://cdn.cloudflare.steamstatic.com/apps/dota2/images/dota_react/icons/hero_strength.png";
            
            cardsHTML += `
                <div class="hero-card" data-hero-name="${hero.name}" data-hero-attribute="${hero.attribute}" data-hero-difficulty="${hero.difficulty}">
                    <img class="hero-img" src="${imageUrl}" alt="${hero.name}" 
                         onerror="this.onerror=null; this.src='${fallbackImg}'; this.style.objectFit='contain'; this.style.background='#0f141c';">
                    <div class="hero-info">
                        <div class="hero-name">${hero.name}</div>
                        <div>
                            <span class="hero-attr"><i class="fas fa-bolt"></i> ${hero.attribute}</span>
                            <span class="hero-difficulty"><i class="fas fa-chart-line"></i> ${hero.difficulty}</span>
                        </div>
                    </div>
                </div>
            `;
        }
        heroesContainer.innerHTML = cardsHTML;
    }

    // Функция-обработчик поиска
    function handleSearch() {
        currentFilter = searchInput.value;
        renderHeroes(currentFilter);
    }

    // Сброс поиска
    function clearSearch() {
        searchInput.value = "";
        currentFilter = "";
        renderHeroes("");
        // Фокус на поле
        searchInput.focus();
    }

    // Рандомный герой из текущего отфильтрованного списка (или из всех, если фильтр пуст)
    function randomHero() {
        let sourceArray = heroesData;
        const lowerFilter = currentFilter.toLowerCase().trim();
        if (lowerFilter !== "") {
            sourceArray = heroesData.filter(hero => hero.name.toLowerCase().includes(lowerFilter));
        }
        if (sourceArray.length === 0) {
            // Если нет героев в отфильтрованном списке — берем всех
            sourceArray = heroesData;
        }
        if (sourceArray.length === 0) return;
        const randomIndex = Math.floor(Math.random() * sourceArray.length);
        const chosen = sourceArray[randomIndex];
        // Красивое сообщение с информацией
        alert(`✨ Случайный герой: ${chosen.name} ✨\n🎭 Атрибут: ${chosen.attribute}\n📈 Сложность: ${chosen.difficulty}\n\n"Да прибудет с тобой сила Древних!"`);
        // Дополнительно: поиск по имени в поле ввода (необязательно, но приятно)
        if (searchInput.value !== chosen.name) {
            searchInput.value = chosen.name;
            handleSearch();  // обновляем сетку с этим героем
        } else {
            // Если уже такой же поиск, просто подсветим карточку? оставим как есть
            // но можно ничего не делать
        }
    }

    // Делегирование событий для кликов по карточкам (всплытие)
    function setupCardClickDelegation() {
        heroesContainer.addEventListener('click', (e) => {
            // Ищем ближайшую карточку .hero-card
            const card = e.target.closest('.hero-card');
            if (!card) return;
            const heroName = card.getAttribute('data-hero-name');
