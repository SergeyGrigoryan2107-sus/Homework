    <label for="rate">Как вы оцениваете удобство сайта?</label><br>
    <label><input type="radio" id="rate" name="rate" value="Отлично" required> Отлично</label><br>
    <label><input type="radio" id="rate" name="rate" value="Хорошо"> Хорошо</label><br>
    <label><input type="radio" id="rate" name="rate" value="Удовлетворительно"> Удовлетворительно</label><br>
    
    <label forsuggestion">Что можно улучшить?</label><br>
    <textarea namesuggestion" rows=4 style='width:100%; padding:10px; border-radius:6px; border:1px solid #ccc;' placeholder='Ваше предложение...'></textarea><br>
    
    <button typesubmit" classbtn">Отправить отзыв</button>
</form>
