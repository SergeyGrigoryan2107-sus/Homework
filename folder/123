<header>
    <div class="container header-inner">
        <div class="logo">
            <i class="fas fa-skull"></i>
            <span>Serwer 2rbina2rista</span>
        </div>
        <div class="nav-links">
            <a href="#">Арена</a>
            <a href="#heroes">Герои</a>
