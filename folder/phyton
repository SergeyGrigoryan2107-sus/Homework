from flask import Flask, request, render_template_string, redirect, url_for
import os

app = Flask(__name__)

# Путь к файлу с результатами
RESULTS_FILE = 'survey_results.txt'

# HTML-шаблон страницы опроса (внутри Python-кода для простоты)
SURVEY_HTML = """
