"""

def save_result(data):
    """Сохраняет результат опроса в файл."""
    with open(RESULTS_FILE, 'a', encoding='utf-8') as f:
        f.write(f"{data['rate']} | {data['suggestion']}\n")

@app.route('/', methods=['GET', 'POST'])
def survey():
    if request.method == 'POST':
        # Получаем данные из формы
        rate = request.form.get('rate')
        suggestion = request.form.get('suggestion', '').strip()
        
        # Если поле предложения пустое, пишем 'Нет ответа'
        if not suggestion:
            suggestion = 'Нет ответа'
        
        # Сохраняем результат
        save_result({'rate': rate, 'suggestion': suggestion})
        
        # Показываем страницу с благодарностью
        return render_template_string(SURVEY_HTML, success=True)
    
    # Показываем форму опроса при GET-запросе
    return render_template_string(SURVEY_HTML)

if __name__ == '__main__':
    # Убеждаемся, что файл для результатов существует
    if not os.path.exists(RESULTS_FILE):
        open(RESULTS_FILE, 'w').close()
    
    print("Опрос запущен. Откройте http://127.0.0.1:5000/ в браузере.")
    app.run(debug=True)
